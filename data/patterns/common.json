  "red_flag_rules": [
    {
      "id": "common_otp_request",
      "requires_any": ["otp_requested"],
      "red_flag": "They are asking for an OTP. No genuine company, bank, or government office ever asks for your OTP. Sharing it gives them access to your account.",
      "severity": "high"
    },
    {
      "id": "common_bank_details_request",
      "requires_any": ["bank_or_card_details_requested"],
      "red_flag": "They are asking for bank, card or UPI PIN details. Genuine employers, lenders and delivery agents never need these.",
      "severity": "high"
    },
    {
      "id": "common_threat_language",
      "requires_any": ["threat_or_arrest_language"],
      "red_flag": "The message uses threats of arrest, FIR, or police action. This is a classic 'digital arrest' / impersonation scam tactic. Real police never demand money over phone or WhatsApp.",
      "severity": "high"
    },
    {
      "id": "common_aadhaar_pan_request",
      "requires_any": ["personal_docs_requested"],
      "red_flag": "They are asking you to send a copy or photo of Aadhaar / PAN. Don't share. These can be used to open fake accounts in your name.",
      "severity": "high"
    },
    {
      "id": "common_urgency",
      "requires_any": ["urgency_pressure"],
      "red_flag": "They are pressuring you to decide or pay quickly ('today only', 'limited slots', 'act fast'). Urgency is used to stop you from thinking or asking someone you trust.",
      "severity": "medium"
    },
    {
      "id": "common_secrecy",
      "requires_any": ["secrecy_demanded"],
      "red_flag": "They are asking you to keep it secret or not tell family. Genuine offers welcome you double-checking with people you trust.",
      "severity": "medium"
    },
    {
      "id": "common_offplatform_whatsapp",
      "requires_any": ["whatsapp_only_contact"],
      "red_flag": "They insist on WhatsApp-only contact. Real companies have offices, websites and verified channels — they don't operate exclusively on personal WhatsApp.",
      "severity": "low"
    },
    {
      "id": "common_offplatform_telegram",
      "requires_any": ["telegram_only_contact"],
      "red_flag": "They are pushing you to a Telegram group or channel. Most India-based investment / job / task scams operate via Telegram because the platform is hard to track.",
      "severity": "medium"
    },
    {
      "id": "common_short_url",
      "requires_any": ["link_to_unknown_short_url"],
      "red_flag": "The message uses a shortened link (bit.ly, tinyurl, etc.) which hides the actual destination. Don't click — it could install spyware or open a phishing page.",
      "severity": "medium"
    },
    {
      "id": "common_apk",
      "requires_any": ["apk_install_request"],
      "red_flag": "They are asking you to install a .apk file outside the Play Store. This is the most common way of installing spyware that drains your bank account.",
      "severity": "high"
    },
    {
      "id": "common_prize_won",
      "requires_any": ["prize_or_lottery_won"],
      "red_flag": "Unsolicited 'you have won' / 'lucky winner' messages are almost always scams. You did not enter a contest you don't remember entering.",
      "severity": "high"
    }
  ],

  "common_next_steps": [
    "Do NOT pay any money, however small the amount.",
    "Do NOT share OTP, Aadhaar, PAN, bank details or photos of ID.",
    "Block the sender's number and report the chat as spam.",
    "If you have already paid or shared details, call the cyber crime helpline 1930 immediately and file a complaint at https://cybercrime.gov.in.",
    "Talk to a family member or someone you trust before doing anything more."
  ]
}
